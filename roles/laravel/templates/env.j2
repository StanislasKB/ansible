# roles/laravel/templates/env.j2
# Généré automatiquement par Ansible — ne pas modifier manuellement sur le serveur

APP_NAME={{ laravel_repo_name }}
APP_ENV={{ laravel_env }}
APP_KEY={{ laravel_app_key }}
APP_DEBUG={{ laravel_debug }}
APP_URL={{ laravel_app_url }}
APP_LOCALE={{ laravel_locale | default('en') }}
APP_FALLBACK_LOCALE={{ laravel_fallback_locale | default('en') }}
APP_FAKER_LOCALE={{ laravel_faker_locale | default('en_US') }}
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL={{ laravel_log_level | default('debug') }}

DB_CONNECTION=mysql
DB_HOST={{ db_host }}
DB_PORT={{ db_port }}
DB_DATABASE={{ db_name }}
DB_USERNAME={{ db_username }}
DB_PASSWORD={{ db_password }}

SESSION_DRIVER={{ laravel_session_driver | default('database') }}
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION={{ laravel_queue_connection | default('database') }}
CACHE_STORE={{ laravel_cache_store | default('database') }}

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER={{ mail_mailer | default('log') }}
MAIL_SCHEME=null
MAIL_HOST={{ mail_host | default('127.0.0.1') }}
MAIL_PORT={{ mail_port | default(2525) }}
MAIL_USERNAME={{ mail_username | default('null') }}
MAIL_PASSWORD={{ mail_password | default('null') }}
MAIL_FROM_ADDRESS="{{ mail_from_address | default('hello@example.com') }}"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
